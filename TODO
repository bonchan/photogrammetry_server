https://www.agisoft.com/pdf/metashape_python_api_2_1_2.pdf



backend run from backend
 - python -m main

frontend run from frontend
 - pnpm run dev

#
photogrammetry_project/
├── .env                    # Metashape path, Database URL, etc.
├── package.json            # Root scripts for "pnpm clean"
├── scripts/
│   └── clean.js            # Bulletproof cleanup script
│
├── backend/
│   ├── main.py             # FastAPI entry point (Web Server)
│   ├── worker.py           # Worker entry point (Process Manager)
│   ├── database.py         # SQLAlchemy models and DB helpers
│   ├── .env                # Symbolic link or copy of root .env
│   │
│   ├── core/               # The "Brains"
│   │   ├── base_worker.py  # SIGTERM/SIGINT and generic logic
│   │   └── ms_worker.py    # MetashapeWorker (Inheritance)
│   │
│   ├── tasks/              # Modular Step Logic
